---
import MobileMenuFooter from "virtual:starlight/components/MobileMenuFooter";
import { Badge, Icon } from "@astrojs/starlight/components";

interface SidebarEntry {
  type: "link" | "group";
  label: string;
  href?: string;
  isCurrent?: boolean;
  entries?: SidebarEntry[];
  collapsed?: boolean;
  badge?: { text: string; variant?: string; class?: string };
  attrs?: Record<string, string>;
}

interface Props {
  sublist?: SidebarEntry[];
  nested?: boolean;
}

const { sublist, nested } = Astro.props as Props;
const sidebar = (sublist ?? Astro.locals.starlightRoute.sidebar) as SidebarEntry[];

const iconClassForEntry = (entry: SidebarEntry): string | undefined => {
  const href = entry.href ?? "";
  if (href === "/") return "fa-solid fa-house";
  if (href.includes("/quickstart/")) return "fa-solid fa-rocket";
  if (href.includes("/installing/")) return "fa-solid fa-screwdriver-wrench";
  if (href.includes("/leaderboard/")) return "fa-solid fa-trophy";
  if (href.includes("/submit/")) return "fa-solid fa-paper-plane";
  if (href.includes("/business_domain/")) return "fa-solid fa-briefcase";
  if (href.includes("/dependency_injection/")) return "fa-solid fa-plug";
  if (href.includes("/infrastructure/")) return "fa-solid fa-server";
  if (href.includes("/integration/")) return "fa-solid fa-link";
  if (href.includes("/persistence/")) return "fa-solid fa-database";
  if (href.includes("/presentation/")) return "fa-solid fa-display";
  if (href.includes("/security/")) return "fa-solid fa-shield-halved";
  if (
    href.includes("/cargotracker/") ||
    href.includes("/coffee_shop/") ||
    href.includes("/daytrader/") ||
    href.includes("/petclinic/") ||
    href.includes("/realworld/")
  ) {
    return "fa-solid fa-cube";
  }
  return undefined;
};

const iconClassForGroup = (entry: SidebarEntry): string | undefined => {
  if (entry.type !== "group") return undefined;
  if (entry.label === "ScarfBench") return "fa-solid fa-layer-group";
  if (entry.label === "Benchmark") return "fa-solid fa-flask-vial";
  if (entry.label === "Focused Examples") return "fa-solid fa-bullseye";
  if (entry.label === "Whole Applications") return "fa-solid fa-cubes";
  if (entry.label === "Resources") return "fa-solid fa-book-open";
  return undefined;
};

const hrefForGroup = (entry: SidebarEntry): string | undefined => {
  if (entry.type !== "group") return undefined;
  if (entry.label === "Benchmark") return "/benchmark/";
  if (entry.label === "Focused Examples") return "/focused_examples/";
  if (entry.label === "Whole Applications") return "/whole_applications/";
  return undefined;
};

const groupHasCurrent = (entry: SidebarEntry): boolean => {
  if (entry.type !== "group" || !entry.entries) return false;
  return entry.entries.some((child) =>
    child.type === "link" ? Boolean(child.isCurrent) : groupHasCurrent(child)
  );
};
---

<ul class:list={{ "top-level": !nested }}>
  {
    sidebar.map((entry) => (
      <li>
        {entry.type === "link" ? (
          <a
            href={entry.href}
            aria-current={entry.isCurrent ? "page" : undefined}
            class:list={[{ large: !nested }, entry.attrs?.class]}
            {...entry.attrs}
          >
            <span class="sidebar-item-label">
              {iconClassForEntry(entry) && (
                <i class:list={["sidebar-item-icon", iconClassForEntry(entry)]} aria-hidden="true"></i>
              )}
              <span>{entry.label}</span>
            </span>
            {entry.badge && (
              <Badge variant={entry.badge.variant} class={entry.badge.class} text={entry.badge.text} />
            )}
          </a>
        ) : (
          <details open={groupHasCurrent(entry) || !entry.collapsed}>
            <summary>
              <span class="group-label">
                {hrefForGroup(entry) ? (
                  <a href={hrefForGroup(entry)} class="group-link sidebar-item-label large" data-no-toggle="true">
                    {iconClassForGroup(entry) && (
                      <i class:list={["sidebar-item-icon", iconClassForGroup(entry)]} aria-hidden="true"></i>
                    )}
                    <span>{entry.label}</span>
                  </a>
                ) : (
                  <span class="sidebar-item-label">
                    {iconClassForGroup(entry) && (
                      <i class:list={["sidebar-item-icon", iconClassForGroup(entry)]} aria-hidden="true"></i>
                    )}
                    <span class="large">{entry.label}</span>
                  </span>
                )}
                {entry.badge && (
                  <Badge variant={entry.badge.variant} class={entry.badge.class} text={entry.badge.text} />
                )}
              </span>
              <Icon name="right-caret" class="caret" size="1.25rem" />
            </summary>
            <Astro.self sublist={entry.entries} nested />
          </details>
        )}
      </li>
    ))
  }
</ul>

{!sublist && (
  <div class="md:sl-hidden">
    <MobileMenuFooter />
  </div>
)}

<style>
  @layer starlight.core {
    ul {
      --sl-sidebar-item-padding-inline: 0.5rem;
      list-style: none;
      padding: 0;
    }

    li {
      overflow-wrap: anywhere;
    }

    ul ul li {
      margin-inline-start: var(--sl-sidebar-item-padding-inline);
      border-inline-start: 1px solid var(--sl-color-hairline-light);
      padding-inline-start: var(--sl-sidebar-item-padding-inline);
    }

    .large {
      font-size: var(--sl-text-lg);
      font-weight: 600;
      color: var(--sl-color-white);
    }

    .top-level > li + li {
      margin-top: 0.75rem;
    }

    summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.2em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
      cursor: pointer;
      user-select: none;
    }
    summary::marker,
    summary::-webkit-details-marker {
      display: none;
    }

    .caret {
      transition: transform 0.2s ease-in-out;
      flex-shrink: 0;
    }
    :global([dir="rtl"]) .caret {
      transform: rotateZ(180deg);
    }
    [open] > summary .caret {
      transform: rotateZ(90deg);
    }

    a {
      display: block;
      border-radius: 0.25rem;
      text-decoration: none;
      color: var(--sl-color-gray-2);
      padding: 0.3em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
    }

    .sidebar-item-label {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .group-link {
      padding: 0;
      margin: 0;
      line-height: inherit;
      color: inherit;
      text-decoration: none;
    }

    .sidebar-item-icon {
      width: 1.05em;
      text-align: center;
      opacity: 0.92;
    }

    a:hover,
    a:focus {
      color: var(--sl-color-white);
    }

    [aria-current="page"],
    [aria-current="page"]:hover,
    [aria-current="page"]:focus {
      font-weight: 600;
      color: var(--sl-color-text-invert);
      background-color: var(--sl-color-text-accent);
    }

    a > *:not(:last-child),
    .group-label > *:not(:last-child) {
      margin-inline-end: 0.25em;
    }

    @media (min-width: 50rem) {
      .top-level > li + li {
        margin-top: 0.5rem;
      }
      .large {
        font-size: var(--sl-text-base);
      }
      a {
        font-size: var(--sl-text-sm);
      }
    }
  }
</style>
