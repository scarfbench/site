---
import { formatMetric, metricClass, type RankedRow, type Solution } from "./data";

interface Props {
    tableId: string;
    rows: RankedRow[];
    solutions: Solution[];
    layerIdx: number;
}

const { tableId, rows, solutions, layerIdx } = Astro.props as Props;
---

<div class="table-wrap">
    <table>
        <colgroup>
            <col class="col-rank" />
            <col class="col-solution" />
            <col class="col-solution" />
            <col class="col-pass1" />
            <col class="col-pass1" />
            <col class="col-pass1 col-pass-focus" />
            <col class="col-pass3 col-group-divider" />
            <col class="col-pass3" />
            <col class="col-pass3 col-pass-focus" />
        </colgroup>
        <thead>
            <tr>
                <th rowspan="2">Rank</th>
                <th rowspan="2">
                    <button type="button" class="sort-button" data-sort-key="agent">
                        <span>Agent</span>
                        <span class="sort-glyphs" aria-hidden="true">
                            <span class="sort-up">▴</span>
                            <span class="sort-down">▾</span>
                        </span>
                    </button>
                </th>
                <th rowspan="2">
                    <button type="button" class="sort-button" data-sort-key="model">
                        <span>Model</span>
                        <span class="sort-glyphs" aria-hidden="true">
                            <span class="sort-up">▴</span>
                            <span class="sort-down">▾</span>
                        </span>
                    </button>
                </th>
                <th class="group-head num group-pass1" colspan="3">Pass@1</th>
                <th class="group-head num group-pass3" colspan="3">Pass@3</th>
            </tr>
            <tr>
                <th class="num group-pass1">
                    <button type="button" class="sort-button num" data-sort-key="compile1">
                        <span>Compile</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num group-pass1">
                    <button type="button" class="sort-button num" data-sort-key="run1">
                        <span>Deploy</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num group-pass1 metric-pass-col">
                    <button type="button" class="sort-button num metric-pass-sort" data-sort-key="pass1">
                        <span>Test</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num group-pass3 group-divider">
                    <button type="button" class="sort-button num" data-sort-key="compile3">
                        <span>Compile</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num group-pass3">
                    <button type="button" class="sort-button num" data-sort-key="run3">
                        <span>Deploy</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num group-pass3 metric-pass-col">
                    <button type="button" class="sort-button num metric-pass-sort active" data-sort-key="pass3">
                        <span>Test</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
            </tr>
        </thead>
        <tbody id={tableId}>
            {
                rows.map((row, rowIdx) => {
                    const solution = solutions[row.solutionIdx];
                    return (
                        <tr
                            class="data-row"
                            data-row-clickable="true"
                            data-table-id={tableId}
                            data-row-idx={String(rowIdx)}
                            data-solution-idx={String(row.solutionIdx)}
                            data-layer-idx={String(layerIdx)}
                        >
                            <td class="rank num">
                                {solution.submission ? (
                                    <a href={solution.submission} class="rank-link" target="_blank" rel="noopener" onclick="event.stopPropagation()">#{row.rank}<sup class="rank-star">*</sup></a>
                                ) : (
                                    <span>#{row.rank}</span>
                                )}
                            </td>
                            <td><strong class="solution-name">{solution.agent}</strong></td>
                            <td>{solution.model}</td>
                            <td class:list={["num", "group-pass1", metricClass(row.compile1, 0)]}>{formatMetric(row.compile1)}</td>
                            <td class:list={["num", "group-pass1", metricClass(row.run1, 1)]}>{formatMetric(row.run1)}</td>
                            <td class:list={["num", "group-pass1", "metric-pass-col", metricClass(row.pass1, 2)]}>{formatMetric(row.pass1)}</td>
                            <td class:list={["num", "group-pass3", "group-divider", metricClass(row.compile3, 0)]}>{formatMetric(row.compile3)}</td>
                            <td class:list={["num", "group-pass3", metricClass(row.run3, 1)]}>{formatMetric(row.run3)}</td>
                            <td class:list={["num", "group-pass3", "metric-pass-col", metricClass(row.pass3, 2)]}>{formatMetric(row.pass3)}</td>
                        </tr>
                    );
                })
            }
        </tbody>
    </table>
</div>
