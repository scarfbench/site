---
import { formatMetric, metricClass, type RankedRow, type Solution } from "./data";

interface Props {
    tableId: string;
    rows: RankedRow[];
    solutions: Solution[];
    layerIdx: number;
}

const { tableId, rows, solutions, layerIdx } = Astro.props as Props;
---

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th rowspan="2">Rank</th>
                <th rowspan="2">
                    <button type="button" class="sort-button" data-sort-key="name">
                        <span>Tool / Model</span>
                        <span class="sort-glyphs" aria-hidden="true">
                            <span class="sort-up">▴</span>
                            <span class="sort-down">▾</span>
                        </span>
                    </button>
                </th>
                <th rowspan="2">
                    <button type="button" class="sort-button" data-sort-key="date">
                        <span>Date</span>
                        <span class="sort-glyphs" aria-hidden="true">
                            <span class="sort-up">▴</span>
                            <span class="sort-down">▾</span>
                        </span>
                    </button>
                </th>
                <th class="group-head num" colspan="3">Pass@1</th>
                <th class="group-head num" colspan="3">Pass@3</th>
                <th class="submission-cell" rowspan="2">Submission</th>
            </tr>
            <tr>
                <th class="num">
                    <button type="button" class="sort-button num" data-sort-key="compile1">
                        <span>Compile</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num">
                    <button type="button" class="sort-button num" data-sort-key="run1">
                        <span>Deploy</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num">
                    <button type="button" class="sort-button num" data-sort-key="pass1">
                        <span>Test</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num">
                    <button type="button" class="sort-button num" data-sort-key="compile3">
                        <span>Compile</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num">
                    <button type="button" class="sort-button num" data-sort-key="run3">
                        <span>Deploy</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
                <th class="num">
                    <button type="button" class="sort-button num active" data-sort-key="pass3">
                        <span>Test</span>
                        <span class="sort-glyphs" aria-hidden="true"><span class="sort-up">▴</span><span class="sort-down">▾</span></span>
                    </button>
                </th>
            </tr>
        </thead>
        <tbody id={tableId}>
            {
                rows.map((row, rowIdx) => {
                    const solution = solutions[row.solutionIdx];
                    return (
                        <tr
                            class="data-row"
                            data-row-clickable="true"
                            data-table-id={tableId}
                            data-row-idx={String(rowIdx)}
                            data-solution-idx={String(row.solutionIdx)}
                            data-layer-idx={String(layerIdx)}
                        >
                            <td class="rank num">#{row.rank}</td>
                            <td>
                                <strong class="solution-name">{solution.name}</strong>
                                <div class="solution-model-line">
                                    <em>({solution.model})</em>
                                </div>
                            </td>
                            <td class="solution-date">{solution.date}</td>
                            <td class:list={["num", metricClass(row.compile1, 0)]}>{formatMetric(row.compile1)}</td>
                            <td class:list={["num", metricClass(row.run1, 1)]}>{formatMetric(row.run1)}</td>
                            <td class:list={["num", metricClass(row.pass1, 2)]}>{formatMetric(row.pass1)}</td>
                            <td class:list={["num", metricClass(row.compile3, 0)]}>{formatMetric(row.compile3)}</td>
                            <td class:list={["num", metricClass(row.run3, 1)]}>{formatMetric(row.run3)}</td>
                            <td class:list={["num", metricClass(row.pass3, 2)]}>{formatMetric(row.pass3)}</td>
                            <td class="submission-cell">
                                <a class="submission-link" href="#" aria-label="Submission URL">
                                    <i class="fa-solid fa-link" aria-hidden="true" />
                                </a>
                            </td>
                        </tr>
                    );
                })
            }
        </tbody>
    </table>
</div>
